# Copy to .env.local and fill in. See docs/getting-started.md.
#
# NEXT_PUBLIC_* vars are required — embedded Studio runs in the browser and
# only reads these (not SANITY_STUDIO_*).

NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
NEXT_PUBLIC_SANITY_STUDIO_BASE_PATH=/studio

# Optional CLI aliases (sanity CLI only — not exposed to browser)
# SANITY_STUDIO_PROJECT_ID=
# SANITY_STUDIO_DATASET=production

# Required for draft mode / live preview (Viewer token)
# Legacy alias SANITY_API_READ_TOKEN also works via env.ts fallback
SANITY_API_VIEW_TOKEN=

# Required for contact form submissions (write to Sanity)
# SANITY_API_EDIT_TOKEN=

# Webhook secret for cache revalidation (configure in Sanity webhook)
# SANITY_REVALIDATE_SECRET=

# HTTP Basic Auth (staging). See docs/features/basic-auth.md
# BASIC_AUTH_USERNAME=
# BASIC_AUTH_PASSWORD=

# Contact form notifications
# RESEND_API_KEY=
# RESEND_EMAIL_FROM=

# Umami analytics (optional)
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# NEXT_PUBLIC_UMAMI_HOST=https://cloud.umami.is

# Mux video uploads in Studio (not needed on frontend)
SANITY_STUDIO_MUX_TOKEN_ID=
SANITY_STUDIO_MUX_TOKEN_SECRET=

NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"

# Required for draft mode / live preview — create at sanity.io/manage → API → Tokens
SANITY_API_READ_TOKEN="your-read-token"

# API version date (optional, defaults to today)
# NEXT_PUBLIC_SANITY_API_VERSION="2024-01-01"

# Your deployed Sanity Studio URL (optional, defaults to localhost:3333 in dev)
# NEXT_PUBLIC_SANITY_STUDIO_URL="https://your-studio.sanity.studio"

# Webhook secret for cache revalidation (optional)
# SANITY_REVALIDATE_SECRET="your-webhook-secret"

# ── Site-wide password gate ──────────────────────────────────────────────────
# Set SITE_PROTECTION_ENABLED=true to require a password to access the entire site.
# Useful for staging environments. Both vars must be set together.
# SITE_PROTECTION_ENABLED="true"
# SITE_PASSWORD="your-site-password"

# ── Mux video ────────────────────────────────────────────────────────────────
# No Mux env vars are required in the frontend. Videos use the public playbackId
# stored in Sanity documents. Mux API tokens belong in studio/.env.local only.
# See /posts/mux-video-setup for the full setup guide.

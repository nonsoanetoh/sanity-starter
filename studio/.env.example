# Studio reads SANITY_STUDIO_* variables (Sanity convention)
# OR NEXT_PUBLIC_* variables (Next.js convention) as a fallback.
# You can share a single .env.local across both packages if you prefer.

SANITY_STUDIO_PROJECT_ID="your-project-id"
SANITY_STUDIO_DATASET="production"

# --- OR use the Next.js-prefixed names (either works) ---
# NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
# NEXT_PUBLIC_SANITY_DATASET="production"

# Your deployed frontend URL for live preview (defaults to localhost in dev)
SANITY_STUDIO_PREVIEW_URL="http://localhost:3000"

# Optional: custom hostname for the deployed Studio (e.g. "my-studio" → my-studio.sanity.studio)
# SANITY_STUDIO_STUDIO_HOST="my-studio"

# ── Mux video (required for uploads in Studio) ───────────────────────────────
# Create at dashboard.mux.com → Settings → API Access Tokens
# Enable Mux Video Read + Write. Copy Token ID and Secret (secret shown once).
# Restart Studio after adding these. Not needed on the frontend.
SANITY_STUDIO_MUX_TOKEN_ID="your-mux-token-id"
SANITY_STUDIO_MUX_TOKEN_SECRET="your-mux-token-secret"

# See /posts/mux-video-setup (after importing sample data) for the full guide.

import { defineField, defineType } from 'sanity'
import { {{icon}} } from '@sanity/icons'

export const {{schemaName}} = defineType({
  name: '{{schemaName}}',
  title: '{{title}}',
  type: 'object',
  icon: {{icon}},
  fields: [
    defineField({
      name: 'headline',
      title: 'Headline',
      type: 'string',
      validation: (rule) => rule.required(),
    }),
    defineField({
      name: 'subheadline',
      title: 'Subheadline',
      type: 'text',
      rows: 3,
    }),
  ],
  preview: {
    select: { title: 'headline' },
    prepare({ title }) {
      return { title: title ?? '{{title}}', media: {{icon}} }
    },
  },
})
